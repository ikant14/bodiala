# Hotelbeds (APItude) credentials — copy this file to `.env` and fill in the real values.
#
#   cp .env.example .env      # then edit .env with the values from the Hotelbeds APItude portal
#
# `.env` is git-ignored; NEVER commit real secrets. It is loaded at startup by
# DotEnvEnvironmentPostProcessor, which feeds the ${HOTELBEDS_*} placeholders in
# application.properties. Real OS environment variables override anything set here.
#
# NOTE: for local dev you usually don't need real creds — `.\dev.ps1` runs against the
# hotelbeds-stub (:9091) with placeholder creds and never touches the real API.

# --- Hotelbeds APItude ----------------------------------------------------------
# Default supplier for requests that omit ?provider= (currently only hotelbeds is implemented).
HOTEL_PROVIDER=hotelbeds
# From the Hotelbeds APItude portal (Apikey detail). apiKey + secret build the X-Signature.
# If blank, the live endpoints return 503 by design.
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
# Test host by default; production is https://api.hotelbeds.com
HOTELBEDS_BASE_URL=https://api.test.hotelbeds.com
HOTELBEDS_LANGUAGE=ENG
HOTELBEDS_SOURCE_MARKET=

# --- Optional: datasource overrides (defaults already match the local Docker Postgres) ---
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bodiala
# SPRING_DATASOURCE_USERNAME=bodiala
# SPRING_DATASOURCE_PASSWORD=bodiala
