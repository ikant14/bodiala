# RezLive (XMLHUB) credentials — copy this file to `.env` and fill in the real values.
#
#   cp .env.example .env      # then edit .env with the values RezLive issued
#
# `.env` is git-ignored; NEVER commit real secrets. It is loaded at startup by
# DotEnvEnvironmentPostProcessor, which feeds the ${REZLIVE_*} placeholders in
# application.properties. Real OS environment variables override anything set here.

# All three are required for the live endpoints (content / search / booking).
# If any is blank, those endpoints return 503 by design.
REZLIVE_API_KEY=
REZLIVE_AGENT_CODE=
REZLIVE_USER_NAME=

# The sandbox/prod action base URL RezLive issued. Leave unset to keep the test-panel default.
REZLIVE_BASE_URL=

# --- Hotelbeds APItude (the second provider) -----------------------------------
# Pick the active supplier: rezlive (default) or hotelbeds.
HOTEL_PROVIDER=rezlive
# From the Hotelbeds APItude portal (Apikey detail). apiKey + secret build the X-Signature.
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
# Test host by default; production is https://api.hotelbeds.com
HOTELBEDS_BASE_URL=https://api.test.hotelbeds.com
HOTELBEDS_LANGUAGE=ENG
HOTELBEDS_SOURCE_MARKET=

# --- Optional: datasource overrides (defaults already match the local Docker Postgres) ---
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bodiala
# SPRING_DATASOURCE_USERNAME=bodiala
# SPRING_DATASOURCE_PASSWORD=bodiala
